SKYRON_VERSION=0.1.0
POSTGRES_DB=skyron
POSTGRES_USER=skyron
POSTGRES_PASSWORD=skyron
DATABASE_URL=postgresql://skyron:skyron@postgres:5432/skyron
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TASKS_TOPIC=skyron.tasks
KAFKA_RETRY_TOPIC=skyron.tasks.retry
KAFKA_DLQ_TOPIC=skyron.tasks.dlq
MAX_RETRIES=3
RETRY_BASE_SECONDS=2
